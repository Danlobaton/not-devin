{
  "hooks": {
    "PostToolUse": [
      {
        "matcher": "Bash",
        "hooks": [
          {
            "type": "command",
            "command": "\"$CLAUDE_PROJECT_DIR/.claude/hooks/auto-commit.sh\" || true",
            "timeout": 30,
            "statusMessage": "Checking if tests passed to auto-commit..."
          }
        ]
      }
    ]
  }
}
